{
    "name": "webconsulting/shadcn2fluid-templates",
    "type": "typo3-cms-extension",
    "description": "ShadCN/UI design patterns converted to pure Fluid templates with tweakcn theme integration for TYPO3",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "webconsulting studio"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-fluid": "^13.4 || ^14.0",
        "friendsoftypo3/content-blocks": "^1.0 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Shadcn2fluidTemplates\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "shadcn2fluid_templates"
        }
    },
    "config": {
        "sort-packages": true
    }
}

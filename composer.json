{
    "name": "webconsulting/shadcn2fluid-templates",
    "type": "typo3-cms-extension",
    "description": "shadcn/ui-inspired Fluid 5 component library and 250 content elements for TYPO3 14",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "webconsulting studio"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^14.2",
        "typo3/cms-fluid": "^14.2",
        "friendsoftypo3/content-blocks": "^2.1"
    },
    "suggest": {
        "typo3/cms-workspaces": "Recommended to stage and preview content elements in TYPO3 workspaces."
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Shadcn2fluidTemplates\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webconsulting\\Shadcn2fluidTemplates\\Tests\\": "Tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5",
        "typo3/testing-framework": "^9.0"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "shadcn2fluid_templates"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
        "test": "phpunit --configuration=phpunit.xml.dist"
    }
}

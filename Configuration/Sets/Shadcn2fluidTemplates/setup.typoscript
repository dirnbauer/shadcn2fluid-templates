#
# ShadCN to Fluid Templates - TypoScript Setup
#
# The theme CSS path is configurable via the site set setting
# "shadcn2fluid.themeCss" (defaults to the bundled theme).
# Override it per site to use a custom theme, e.g. from tweakcn.com.
#

page {
    includeCSS {
        shadcnTheme = {$shadcn2fluid.themeCss}
        shadcnTheme.media = all

        shadcnComponents = EXT:shadcn2fluid_templates/Resources/Public/Css/components.css
        shadcnComponents.media = all
    }
}
